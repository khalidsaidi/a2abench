{
  "name": "a2abench",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --if-present dev",
    "growth:once": "GROWTH_RUN_ONCE=true pnpm exec tsx scripts/growth-loop.ts",
    "growth:loop": "pnpm exec tsx scripts/growth-loop.ts",
    "traction:once": "AUTOPILOT_RUN_ONCE=true pnpm exec tsx scripts/traction-autopilot.ts",
    "traction:loop": "pnpm exec tsx scripts/traction-autopilot.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0"
  }
}
