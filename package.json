{
  "name": "a2abench",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --if-present dev",
    "benchmark:build-corpus": "pnpm exec tsx scripts/corpus/build-eval-set.ts",
    "benchmark:seed-baseline": "pnpm exec tsx scripts/seed/run-baseline.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0"
  }
}
